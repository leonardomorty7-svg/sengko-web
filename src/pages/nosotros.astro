---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Nosotros | SENGKO Ingeniería Estructural"
  description="SENGKO es una compañía de base ingenieril especializada en el diseño, fabricación y montaje de estructuras metálicas de alto desempeño."
>
  <main class="relative bg-[var(--color-bg)] text-white overflow-x-hidden">

    <!-- ─────────────────────────────────────────── -->
    <!--  1. INTERNAL HERO                           -->
    <!-- ─────────────────────────────────────────── -->
    <section class="relative min-h-[90vh] flex flex-col justify-end pb-32 pt-48 bg-black overflow-hidden">
      <!-- Background Layer -->
      <div class="absolute inset-0 z-0">
        <img
          src="/images/projects/edificio-01.jpg"
          alt="Ingeniería Estructural SENGKO"
          class="w-full h-full object-cover brightness-[0.5] contrast-[1.1] grayscale-[20%]"
        />
        <div class="absolute inset-0 z-10 bg-gradient-to-r from-black/95 via-black/60 to-transparent"></div>
        <div class="absolute inset-0 z-10 bg-gradient-to-t from-black via-transparent to-black/40"></div>
      </div>

      <!-- Content Layer -->
      <div class="container-custom relative z-30">
        <div class="max-w-4xl">
          <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-8 block reveal">
            Compañía de Base Ingenieril
          </span>
          <h1 class="text-[clamp(48px,8vw,110px)] font-medium tracking-tight leading-[0.9] uppercase mb-8 reveal delay-1" style="font-family: var(--font-heading);">
            Ingeniería de<br/>
            <span class="text-white/40">Precisión.</span>
          </h1>
          <p class="text-white/60 text-lg md:text-2xl font-light leading-[1.6] max-w-[35ch] reveal delay-2">
            Especialistas en estructuras metálicas, integrando diseño, fabricación certificada y montaje bajo estrictos estándares industriales.
          </p>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  2. WHO WE ARE                              -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-[#eae8e3] text-black py-32 md:py-48 relative">
      <div class="absolute inset-0 pointer-events-none opacity-[0.02] mix-blend-multiply bg-noise"></div>
      <div class="container-custom relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
          <div class="reveal">
            <span class="section-label section-label--dark">Nuestra Identidad</span>
            <h2 class="text-4xl md:text-6xl font-medium tracking-tight leading-[1.05] mb-10 max-w-[15ch]">
              Excelencia técnica materializada en acero.
            </h2>
            <div class="accent-rule mb-0 opacity-80"></div>
          </div>
          <div class="lg:pt-20 space-y-8 reveal delay-2">
            <p class="text-xl md:text-2xl font-light leading-[1.6] tracking-[-0.01em]">
              SENGKO no es solo una empresa constructora; somos una organización fundamentada en la ingeniería pura.
            </p>
            <p class="text-base text-black/60 leading-[1.8] font-light max-w-[45ch]">
              Nuestra metodología se basa en la integración total de los procesos constructivos. Desde la concepción y modelado BIM estructural hasta la fabricación en planta y el montaje en sitio. Cada decisión está respaldada por cálculos precisos, garantizando infraestructuras metálicas seguras, eficientes y perdurables.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  3. SPECIALIZATION                          -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-black py-32 md:py-48 relative border-b border-white/5">
      <div class="container-custom">
        <div class="mb-24 reveal">
          <span class="section-label">Especialización Técnica</span>
          <h2 class="text-4xl md:text-6xl font-medium tracking-tight leading-[1.05] max-w-[20ch]">
            Capacidad integral en infraestructura metálica.
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16 border-t border-white/10 pt-16">
          {[
            {
              title: "Diseño Estructural",
              desc: "Cálculo y optimización de estructuras bajo normativa sismorresistente vigente, garantizando seguridad y eficiencia en el uso del acero."
            },
            {
              title: "Modelado BIM",
              desc: "Desarrollo de gemelos digitales detallados para coordinación interdisciplinaria, eliminando interferencias y optimizando el despiece."
            },
            {
              title: "Fabricación",
              desc: "Transformación del acero en planta bajo estrictos controles dimensionales, con equipos de corte y soldadura de alta tecnología."
            },
            {
              title: "Montaje Estructural",
              desc: "Ejecución en obra mediante cuadrillas especializadas y equipos de izaje, priorizando la seguridad y precisión en las conexiones."
            },
            {
              title: "Inspección Técnica",
              desc: "Supervisión rigurosa de soldaduras y ensambles por profesionales certificados, asegurando integridad mecánica."
            },
            {
              title: "Control de Calidad",
              desc: "Implementación de protocolos de aseguramiento de calidad en cada fase, documentando la trazabilidad de materiales y procesos."
            }
          ].map((item, i) => (
            <div class:list={["reveal", `delay-${(i % 3) + 1}`]}>
              <span class="text-[var(--color-primary)] text-[10px] uppercase tracking-[0.2em] font-medium mb-4 block">0{i+1}</span>
              <h3 class="text-xl md:text-2xl font-medium mb-4 text-white">{item.title}</h3>
              <p class="text-white/50 text-sm font-light leading-[1.7] max-w-[35ch]">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  4. WORK PHILOSOPHY                         -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-[#111] py-32 md:py-48">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="order-2 lg:order-1 relative aspect-square md:aspect-[4/3] lg:aspect-[3/4] overflow-hidden reveal">
            <img src="/images/services/structural-design.jpg" alt="Filosofía SENGKO" class="w-full h-full object-cover grayscale brightness-75 contrast-125" />
            <div class="absolute inset-0 border border-white/10 m-4 pointer-events-none"></div>
          </div>
          <div class="order-1 lg:order-2 lg:pl-16 reveal delay-2">
            <span class="section-label">Filosofía Corporativa</span>
            <h2 class="text-4xl md:text-5xl font-medium tracking-tight leading-[1.1] mb-12">
              Principios inquebrantables.
            </h2>
            <div class="space-y-8">
              <div class="flex gap-6 border-b border-white/10 pb-8">
                <div class="text-[var(--color-primary)] opacity-80 mt-1">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                <div>
                  <h4 class="text-white text-lg font-medium mb-2">Responsabilidad</h4>
                  <p class="text-white/50 text-sm font-light leading-[1.6]">Cumplimiento estricto de cronogramas, presupuestos y normativas de seguridad, entendiendo el impacto de nuestras estructuras.</p>
                </div>
              </div>
              <div class="flex gap-6 border-b border-white/10 pb-8">
                <div class="text-[var(--color-primary)] opacity-80 mt-1">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="M22 4L12 14.01l-3-3"></path></svg>
                </div>
                <div>
                  <h4 class="text-white text-lg font-medium mb-2">Honestidad Técnica</h4>
                  <p class="text-white/50 text-sm font-light leading-[1.6]">Transparencia absoluta en nuestras recomendaciones de ingeniería, optimizaciones estructurales y reporte de procesos.</p>
                </div>
              </div>
              <div class="flex gap-6 pb-8">
                <div class="text-[var(--color-primary)] opacity-80 mt-1">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <div>
                  <h4 class="text-white text-lg font-medium mb-2">Trabajo en Equipo</h4>
                  <p class="text-white/50 text-sm font-light leading-[1.6]">Coordinación milimétrica entre calculistas, modeladores, soldadores y montadores para garantizar una ejecución impecable.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  5. TECHNICAL BACKING (GEO & SEMANTIC)      -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-black py-32 md:py-48 border-y border-white/10">
      <div class="container-custom text-center max-w-4xl">
        <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-8 block reveal">Respaldo Técnico</span>
        <h2 class="text-3xl md:text-5xl font-medium tracking-tight leading-[1.1] mb-12 reveal delay-1">
          Operamos bajo los más altos estándares de la industria metalmecánica.
        </h2>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16 border-t border-white/10 pt-16 reveal delay-2">
          <div class="flex flex-col items-center text-center gap-4">
            <span class="text-white text-2xl font-medium tracking-widest">AWS D1.1</span>
            <span class="text-white/40 text-xs font-light uppercase tracking-widest">Normativa<br/>Soldadura</span>
          </div>
          <div class="flex flex-col items-center text-center gap-4">
            <span class="text-white text-2xl font-medium tracking-widest">BIM</span>
            <span class="text-white/40 text-xs font-light uppercase tracking-widest">Flujo de<br/>Trabajo VDC</span>
          </div>
          <div class="flex flex-col items-center text-center gap-4">
            <span class="text-white text-2xl font-medium tracking-widest">100%</span>
            <span class="text-white/40 text-xs font-light uppercase tracking-widest">Trazabilidad<br/>Materiales</span>
          </div>
          <div class="flex flex-col items-center text-center gap-4">
            <span class="text-white text-2xl font-medium tracking-widest">NSR-10</span>
            <span class="text-white/40 text-xs font-light uppercase tracking-widest">Cumplimiento<br/>Sismorresistente</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  6. EXPERIENCE / CLIENTS                    -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-[#050505] py-32 md:py-48">
      <div class="container-custom">
        <div class="mb-20 text-center reveal">
          <span class="section-label">Experiencia Comprobada</span>
          <h2 class="text-3xl md:text-5xl font-medium tracking-tight mb-6">Confianza Industrial</h2>
          <p class="text-white/40 text-sm font-light max-w-[50ch] mx-auto">
            Hemos desarrollado y ejecutado infraestructura crítica para empresas líderes a nivel nacional, demostrando nuestra capacidad de respuesta y solvencia técnica.
          </p>
        </div>
        
        <div class="flex flex-wrap justify-center gap-x-16 gap-y-12 items-center opacity-60 reveal delay-2 grayscale">
          <span class="text-2xl md:text-4xl font-heading font-semibold tracking-tighter uppercase">Postobón</span>
          <span class="text-2xl md:text-4xl font-heading font-semibold tracking-tighter uppercase">Gonvarri</span>
          <span class="text-2xl md:text-4xl font-heading font-semibold tracking-tighter uppercase">Cory</span>
          <span class="text-2xl md:text-4xl font-heading font-semibold tracking-tighter uppercase">Hatovial</span>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────────────────────── -->
    <!--  7. FINAL CTA                               -->
    <!-- ─────────────────────────────────────────── -->
    <section class="relative py-40 md:py-56 bg-black overflow-hidden flex items-center justify-center">
      <div class="absolute inset-0 z-0">
        <img src="/projects/postobon-01.jpg" alt="Contacto" class="w-full h-full object-cover brightness-[0.2] grayscale contrast-125 scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent"></div>
      </div>
      
      <div class="container-custom relative z-10 text-center max-w-3xl">
        <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-8 block reveal">Inicie su Proyecto</span>
        <h2 class="text-4xl md:text-6xl font-medium tracking-tight leading-[1.05] mb-12 reveal delay-1">
          Ingeniería estructurada para resultados reales.
        </h2>
        <div class="reveal delay-2">
          <button data-modal-trigger="consultation" class="px-12 py-5 bg-[var(--color-primary)] text-black text-[10px] font-semibold tracking-[0.16em] uppercase hover:bg-white transition-all duration-400">
            Iniciar Consulta Técnica
          </button>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Reveal animations
  const DELAY_MAP: Record<string, number> = {
    'delay-1': 0.15,
    'delay-2': 0.3,
    'delay-3': 0.45,
    'delay-4': 0.6,
  };

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
    let delay = 0;
    for (const [cls, val] of Object.entries(DELAY_MAP)) {
      if (el.classList.contains(cls)) { delay = val; break; }
    }

    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 1.2,
        delay,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true
        }
      }
    );
  });
</script>

<style>
  .bg-noise {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  }
  .font-heading {
    font-family: var(--font-heading);
  }
</style>
