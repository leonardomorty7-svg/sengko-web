---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects, getServices } from '../lib/api';
import ServiceCard from '../components/astro/ServiceCard.astro';
import ProjectCard from '../components/astro/ProjectCard.astro';
import { siteConfig } from '../data/site-config';
import ScrollNarrative from '../components/astro/ScrollNarrative.astro';

import { projects } from '../data/projects';

const services = await getServices();
const serviceImages = [
  '/images/services/structural-design.jpg',
  '/images/services/bim-modeling.jpg',
  '/images/services/metal-fabrication.jpg',
];
---

<BaseLayout>
  <main class="relative bg-[var(--color-bg)] text-white overflow-x-hidden">

    <!-- ─────────────────────────────────────────── -->
    <!--  1. HERO NARRATIVE — scroll-driven scene    -->
    <!-- ─────────────────────────────────────────── -->
    <section id="hero-narrative" class="hero-scroll relative bg-black">
      <div class="hero-sticky">
        <!-- Background Layer -->
        <div class="absolute inset-0 z-0">
          <img
            id="hero-image"
            src="/images/hero/postobon-hero.jpg"
            alt="SENGKO – Ingeniería Estructural"
            class="w-full h-full object-cover brightness-[0.7] contrast-[1.05]"
            style="will-change: transform;"
          />
          <!-- Editorial gradient overlay -->
          <div class="absolute inset-0 z-10 bg-gradient-to-r from-black/95 via-black/60 to-transparent"></div>
          
        </div>

        <!-- Content Layer -->
        <div class="container-custom relative z-30 h-full flex flex-col justify-center">
          <div class="hero-content-narrative">
            <span class="hero-eyebrow mb-6 block" id="hero-eyebrow">INGENIERÍA ESTRUCTURAL DE PRECISIÓN</span>
            
            <div class="hero-text-container relative h-[1.2em] md:h-[2.7em] lg:h-[4.5em]">
              <h1 class="hero-title hero-state absolute top-0 left-0" id="state-1">
                TRANSFORMAMOS ACERO
              </h1>
              <h1 class="hero-title hero-state absolute top-0 left-0 opacity-0" id="state-2">
                EN INFRAESTRUCTURA
              </h1>
              <h1 class="hero-title hero-state absolute top-0 left-0 opacity-0" id="state-3">
                <span class="text-[var(--color-primary)]">DE ALTO DESEMPEÑO.</span>
              </h1>
            </div>

            <div id="hero-meta" class="mt-12 opacity-0">
              <p class="hero-subtext mb-10">
                Diseño, fabricación y montaje estructural con precisión técnica.
              </p>
              <div class="hero-actions flex flex-wrap gap-4">
                <a href="#proyectos" class="px-10 py-5 bg-[var(--color-primary)] text-black text-[10px] font-semibold tracking-[0.16em] uppercase hover:bg-white transition-all duration-400">
                  Ver Proyectos
                </a>
                <a href="#" data-modal-trigger="consultation" class="px-10 py-5 border border-white/20 text-white text-[10px] font-semibold tracking-[0.16em] uppercase hover:bg-white hover:text-black transition-all duration-400">
                  Consulta Técnica
                </a>
              </div>
            </div>
          </div>
          
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center gap-4 opacity-80" id="hero-scroll-indicator">
          <span class="text-[9px] tracking-[0.35em] uppercase text-white font-medium drop-shadow-md">Scroll</span>
          <div class="w-[1px] h-14 bg-white/20 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1/2 bg-white animate-scroll-drop shadow-[0_0_5px_rgba(255,255,255,0.8)]"></div>
          </div>
        </div>
      </div>
    </section>


    <!-- ─────────────────────────────────────────── -->
    <!--  2. INTRO — light, text clarity, numbers    -->
    <!-- ─────────────────────────────────────────── -->
    <section class="editorial-refinement bg-[#eae8e3] text-[var(--color-text-dark)] pt-40 pb-32 md:pt-56 md:pb-48 relative overflow-hidden">
      <!-- Background Texture Layer -->
      <div class="absolute inset-0 pointer-events-none opacity-[0.02] mix-blend-multiply bg-noise"></div>

      <div class="container-custom relative z-10">
        <!-- Editorial Header System -->
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 items-start mb-40">
          <div class="lg:col-span-6 reveal">
            <span class="text-[10px] font-medium uppercase tracking-[0.2em] text-black/40 block mb-16">Sobre SENGKO</span>
            <h2 class="text-[clamp(48px,9vw,110px)] font-medium tracking-[-0.04em] leading-[0.95] uppercase mb-8">
              Estructura.<br/>
              Precisión.<br/>
              <span class="text-black/30">Ejecución.</span>
            </h2>
          </div>
          <div class="lg:col-span-5 lg:col-start-8 lg:pt-32 flex flex-col gap-12 reveal delay-2">
            <p class="text-xl md:text-2xl font-light leading-[1.6] text-[var(--color-text-dark)] tracking-[-0.01em] max-w-[38ch]">
              Especialistas en la integración total de procesos: desde el cálculo y modelado BIM hasta la fabricación y el montaje especializado.
            </p>
            <div class="accent-rule mb-0 opacity-80"></div>
            <p class="text-base md:text-lg text-[var(--color-text-muted-dark)] leading-[1.8] font-light max-w-[40ch]">
              Nuestra metodología garantiza precisión dimensional, optimización de recursos y cumplimiento riguroso de estándares internacionales en cada obra.
            </p>
          </div>
        </div>

        <!-- Integrated Architectural Stats -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-16 border-t border-black/10 pt-16 md:pt-24">
          {[
            { n: '+250', label: 'Proyectos', desc: 'Infraestructura industrial ejecutada' },
            { n: '+15k', label: 'Toneladas', desc: 'Acero fabricado bajo norma' },
            { n: '20+',  label: 'Años',      desc: 'De especialidad técnica' },
            { n: '12',   label: 'Sectores',  desc: 'Atendidos a nivel nacional' },
          ].map((s, i) => (
            <div class:list={["reveal", `delay-${i + 1}`]}>
              <div class="flex flex-col gap-5">
                <span class="text-5xl md:text-[5.5rem] font-light tracking-[-0.04em] text-black leading-none tabular-nums">
                  {s.n}
                </span>
                <div class="space-y-3 max-w-[18ch]">
                  <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-[var(--color-primary-soft)] block">
                    {s.label}
                  </span>
                  <p class="text-[13px] md:text-sm text-black/60 leading-[1.6] font-light">
                    {s.desc}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─────────────────────────────────────────── -->
    <!--  2b. SCROLL NARRATIVE — sticky storytelling -->
    <!-- ─────────────────────────────────────────── -->
    <ScrollNarrative />


    <!-- ─────────────────────────────────────────── -->
    <!--  3. EDITORIAL STATEMENT — dark + image      -->
    <!-- ─────────────────────────────────────────── -->
    <section class="bg-[var(--color-bg)] py-28 md:py-40">
      <div class="container-custom">
        <div class="grid lg:grid-cols-2 gap-10 md:gap-20 items-center">

          <!-- Statement text -->
          <div class="reveal">
            <span class="section-label">Metodología</span>
            <h2 class="text-4xl md:text-[clamp(40px,4.5vw,68px)] font-medium tracking-tight leading-[1.05] mb-10 max-w-[15ch]">
              Cada estructura es el resultado de un proceso riguroso, no de una improvisación.
            </h2>
            <span class="accent-rule"></span>
            <p class="text-white/50 text-base leading-relaxed max-w-[42ch]">
              Integramos diseño estructural, modelado BIM, fabricación certificada e inspección de calidad en cada proyecto que emprendemos. Sin excepción.
            </p>
          </div>

          <!-- Supporting image -->
          <div class="relative aspect-[4/5] overflow-hidden reveal delay-2">
            <img
              src="/images/projects/gonvarri-01.jpg"
              alt="Proceso constructivo SENGKO"
              class="w-full h-full object-cover brightness-90 contrast-110 transition-transform duration-[3s] ease-out hover:scale-105"
            />
            <!-- Image counter badge -->
            <div class="absolute bottom-6 right-6 bg-[var(--color-primary)] px-4 py-2">
              <span class="text-black text-[8px] font-medium tracking-[0.16em] uppercase">Proyecto ejecutado</span>
            </div>
          </div>
        </div>
      </div>
    </section>




    <!-- ─────────────────────────────────────────── -->
    <!--  4. PORTFOLIO NARRATIVE — Cinematic Split System -->
    <!-- ─────────────────────────────────────────── -->
    <section id="proyectos" class="bg-black relative">

      <!-- CINEMATIC PORTFOLIO INTRO -->
      <div class="relative flex items-end justify-center overflow-hidden" style="min-height: 80vh; padding-bottom: 8vh;">
        <!-- Static industrial background -->
        <div class="absolute inset-0 z-0">
          <img
            src="/projects/postobon-01.jpg"
            alt=""
            aria-hidden="true"
            class="w-full h-full object-cover"
            style="filter: brightness(0.1) contrast(1.15) grayscale(1);"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to bottom, #0A0A0A 0%, transparent 20%, transparent 55%, #0A0A0A 85%, #0A0A0A 100%);"></div>
          <div class="absolute inset-0 bg-black/50"></div>
        </div>

        <!-- Content — bottom-anchored for narrative handoff feel -->
        <div class="container-custom relative z-10 px-6" style="padding-top: 10vh;">
          <span class="section-label mb-10 block" style="color: var(--color-primary);">Portafolio</span>
          <h2 style="
            font-family: var(--font-heading);
            font-size: clamp(44px, 9.5vw, 136px);
            font-weight: 500;
            line-height: 0.88;
            letter-spacing: -0.04em;
            text-transform: uppercase;
            color: #fff;
            margin: 0;
          ">
            <span style="display: block; white-space: nowrap;">Infraestructura</span>
            <span style="display: block; white-space: nowrap; color: var(--color-primary);">de alto impacto</span>
            <span style="display: block; white-space: nowrap;">ejecutada.</span>
          </h2>
        </div>
      </div>
      <!-- END CINEMATIC PORTFOLIO INTRO -->


      <div id="projects-story-container" class="relative bg-black w-full" style={`height: ${projects.length * 100}vh; margin-top: -22vh; position: relative; z-index: 2;`}>
        <div class="projects-story-inner sticky top-0 h-screen w-full overflow-hidden hidden lg:grid lg:grid-cols-[30%_70%]">
          
          <!-- LEFT SIDE: TEXT (30%) -->
          <div class="projects-text relative bg-black h-full flex items-center px-8 lg:px-[8vw] z-20 border-r border-white/5">
            {projects.map((p, i) => (
              <div class="project-story-text absolute inset-0 flex items-center px-8 lg:px-[8vw] opacity-0 pointer-events-none" data-index={i}>
                <div class="w-full">
                  <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-6 block">
                    {p.category}
                  </span>
                  <h3 class="text-3xl md:text-5xl font-medium tracking-tight text-white leading-[1.1] mb-10">
                    {p.title}
                  </h3>
                  <div class="space-y-6 border-l border-white/10 pl-8 py-2">
                    <div class="flex flex-col">
                      <span class="text-white/30 text-[9px] uppercase tracking-[0.2em] mb-2">Especificaciones</span>
                      <span class="text-white/90 text-sm font-medium tracking-tight">{p.specs}</span>
                    </div>
                    <div class="flex flex-col">
                      <span class="text-white/30 text-[9px] uppercase tracking-[0.2em] mb-2">Ubicación</span>
                      <span class="text-white/90 text-sm font-medium tracking-tight">{p.location}</span>
                    </div>
                  </div>
                  <div class="mt-10 pointer-events-auto">
                    <a href={`/proyectos/${p.slug}`} class="inline-block border border-white/20 text-white text-[9px] font-semibold tracking-[0.16em] uppercase px-8 py-4 hover:bg-white hover:text-black transition-all duration-400">
                      Ver Proyecto
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- RIGHT SIDE: IMAGE (70%) -->
          <div class="projects-image-wrapper relative bg-black h-full overflow-hidden">
            {projects.map((p, i) => (
              <img 
                src={p.image || p.fallbackImage} 
                alt={p.title}
                class="project-story-img absolute inset-0 w-full h-full object-cover brightness-90 contrast-110 opacity-0 transform scale-[1.05]"
                style="will-change: transform, opacity;"
                onerror={`console.error('Image failed:', '${p.image}')`}
                data-index={i}
              />
            ))}
          </div>
        </div>

        <!-- MOBILE FALLBACK: Simple stacked layout -->
        <div class="lg:hidden container-custom pb-24 space-y-20">
          {projects.map((p) => (
            <div class="flex flex-col gap-8">
              <div class="aspect-[16/10] overflow-hidden">
                <img src={p.image || p.fallbackImage} alt={p.title} class="w-full h-full object-cover" />
              </div>
              <div>
                <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-4 block">{p.category}</span>
                <h3 class="text-3xl font-medium text-white mb-6">{p.title}</h3>
                <div class="grid grid-cols-2 gap-4 border-t border-white/10 pt-6">
                  <div>
                    <span class="text-white/30 text-[8px] uppercase tracking-wider block mb-1">Especificaciones</span>
                    <span class="text-white/80 text-xs">{p.specs}</span>
                  </div>
                  <div>
                    <span class="text-white/30 text-[8px] uppercase tracking-wider block mb-1">Ubicación</span>
                    <span class="text-white/80 text-xs">{p.location}</span>
                  </div>
                </div>
                <div class="mt-6">
                  <a href={`/proyectos/${p.slug}`} class="inline-block border border-white/20 text-white text-[9px] font-semibold tracking-[0.16em] uppercase px-8 py-4 hover:bg-white hover:text-black transition-all duration-400">
                    Ver Proyecto
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ─────────────────────────────────────────── -->
    <!--  6. SERVICES — light section, visual relief -->
    <!-- ─────────────────────────────────────────── -->
    <section id="servicios" class="relative z-50 bg-white text-[var(--color-text-dark)] py-28 md:py-40" style="isolation: isolate;">
      <div class="container-custom mb-32 md:mb-40">
        <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-end reveal">
          <div>
            <span class="section-label section-label--dark mb-10">Capacidades</span>
            <h2 class="text-4xl md:text-[clamp(48px,5vw,72px)] font-medium tracking-[-0.03em] leading-[1.05] max-w-[15ch]">
              Ingeniería integral, de principio a fin.
            </h2>
          </div>
          <p class="text-[var(--color-text-muted-dark)] text-lg font-light leading-[1.8] max-w-[42ch] reveal delay-2 md:self-end pb-2">
            Cada capacidad está diseñada para funcionar en conjunto, garantizando coherencia técnica y precisión dimensional en toda la cadena del proyecto.
          </p>
        </div>
      </div>

      <div class="container-custom space-y-32 md:space-y-48">
        {services.slice(0, 3).map((service, i) => (
          <div class:list={["reveal", i > 0 && `delay-${i}`]}>
            <ServiceCard
              title={service.title}
              description={service.description}
              index={i}
              image={serviceImages[i]}
            />
          </div>
        ))}
      </div>
    </section>


  </main>

  <!-- ─────────────────────────────────────────── -->
  <!--  7. CINEMATIC OUTRO & FOOTER                -->
  <!-- ─────────────────────────────────────────── -->
  <div id="outro-section" class="relative bg-black overflow-hidden flex flex-col justify-between min-h-[90vh]">
    
    <!-- Shared Cinematic Background -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/projects/edificio-01.jpg"
        alt="Contacto SENGKO"
        class="cinematic-outro-img absolute inset-0 w-full h-full object-cover grayscale-[30%] contrast-125 brightness-50"
      />
      <!-- Overlays for legibility: Darker at bottom for footer, gradient on left for CTA -->
      <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-white to-transparent opacity-5"></div>
    </div>

    <section id="contacto" class="relative z-10 flex-grow flex items-center justify-start">
      <!-- Left-aligned content — mirrors hero -->
      <div class="container-custom py-32 w-full">
        <div class="max-w-[560px]">
          <span class="section-label reveal">Siguiente Paso</span>
          <h2 class="text-4xl md:text-[clamp(48px,5vw,72px)] font-medium tracking-[-0.02em] leading-[1.05] mb-8 reveal delay-1">
            Hablemos sobre su próximo <span class="text-[var(--color-primary)]">desafío estructural.</span>
          </h2>
          <p class="text-white/60 text-lg font-light leading-[1.8] mb-12 max-w-[42ch] reveal delay-2">
            Analizamos sus requerimientos técnicos y desarrollamos infraestructura de alto desempeño adaptada a cada proyecto.
          </p>
          <div class="flex flex-wrap gap-4 reveal delay-3">
            <a
              href="#"
              data-modal-trigger="consultation"
              class="px-10 py-5 bg-[var(--color-primary)] text-black text-[9px] font-medium tracking-[0.14em] uppercase hover:bg-white transition-colors duration-500"
            >
              Iniciar Consulta Técnica
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Integrated Corporate Footer -->
    <footer class="relative z-10 border-t border-white/10 py-16 mt-auto bg-[#050505]">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-24 mb-16">
        
        <!-- Branding & Descriptor -->
        <div class="md:col-span-2">
          <img src="/images/branding/logo-sengko-primary.svg" alt="SENGKO" class="h-6 mb-6 opacity-80" />
          <p class="text-white/40 text-sm leading-[1.8] font-light max-w-[35ch]">
            Ingeniería de alto desempeño enfocada en el diseño, fabricación y montaje de infraestructura metálica con precisión técnica.
          </p>
        </div>

        <!-- Corporate Info -->
        <div>
          <span class="text-[var(--color-primary)] text-[9px] uppercase tracking-[0.2em] font-medium mb-6 block">Oficina Principal</span>
          <address class="not-italic text-white/50 text-sm font-light leading-[1.8] space-y-2">
            <p>{siteConfig.contact.address}</p>
            <p class="pt-2"><a href={`mailto:${siteConfig.contact.email}`} class="hover:text-white transition-colors">{siteConfig.contact.email}</a></p>
            <p><a href={`tel:${siteConfig.contact.phone.replace(/[^0-9+]/g, '')}`} class="hover:text-white transition-colors">{siteConfig.contact.phone}</a></p>
          </address>
        </div>

        <!-- Navigation -->
        <div>
          <span class="text-[var(--color-primary)] text-[9px] uppercase tracking-[0.2em] font-medium mb-6 block">Navegación</span>
          <nav class="flex flex-col gap-3">
            <a href="/#proyectos" class="text-white/50 hover:text-white transition-colors text-sm font-light">Proyectos</a>
            <a href="/#servicios" class="text-white/50 hover:text-white transition-colors text-sm font-light">Servicios</a>
            <a href="/nosotros" class="text-white/50 hover:text-white transition-colors text-sm font-light">Nosotros</a>
            <a href="/#contacto" class="text-white/50 hover:text-white transition-colors text-sm font-light">Contacto</a>
          </nav>
        </div>

      </div>

      <!-- Bottom Bar -->
      <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-6">
        <small class="text-white/30 font-normal tracking-wider text-[10px]">© {new Date().getFullYear()} {siteConfig.title}</small>
        <div class="flex gap-6">
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-white transition-colors text-[10px] tracking-wider uppercase">LinkedIn</a>
          <a href={siteConfig.social.twitter} target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-white transition-colors text-[10px] tracking-wider uppercase">Twitter</a>
        </div>
      </div>
    </div>
  </footer>
  </div> <!-- End outro-section -->

</BaseLayout>


<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Cinematic Outro Parallax ──────────────────────────────────
  const outroSection = document.getElementById('outro-section');
  const outroImg = document.querySelector('.cinematic-outro-img');
  
  if (outroSection && outroImg) {
    gsap.fromTo(outroImg,
      { scale: 1 },
      {
        scale: 1.05, // Very subtle, slow zoom
        ease: 'none',
        scrollTrigger: {
          trigger: outroSection,
          start: 'top bottom',
          end: 'bottom bottom',
          scrub: true
        }
      }
    );
  }

  // ── Reveal on scroll ────────────────────────────────────────
  // Map delay classes → seconds
  const DELAY_MAP: Record<string, number> = {
    'delay-1': 0.1,
    'delay-2': 0.2,
    'delay-3': 0.35,
    'delay-4': 0.5,
  };

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
    let delay = 0;
    for (const [cls, val] of Object.entries(DELAY_MAP)) {
      if (el.classList.contains(cls)) { delay = val; break; }
    }

    gsap.fromTo(el,
      { opacity: 0, y: 28 },
      {
        opacity: 1,
        y: 0,
        duration: 1.1,
        delay,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: el.closest('#servicios') ? 'top 65%' : 'top 88%',
          once: true
        }
      }
    );
  });

  // ── Hero Scroll Narrative System ──────────────────────────
  const heroSec = document.getElementById('hero-narrative');
  const heroImage = document.getElementById('hero-image');
  const eyebrow = document.getElementById('hero-eyebrow');
  const state1 = document.getElementById('state-1');
  const state2 = document.getElementById('state-2');
  const state3 = document.getElementById('state-3');
  const heroMeta = document.getElementById('hero-meta');
  const scrollInd = document.getElementById('hero-scroll-indicator');

  if (heroSec && window.innerWidth >= 1024) {
    const heroTl = gsap.timeline({
      scrollTrigger: {
        trigger: heroSec,
        start: 'top top',
        end: '+=2000',
        scrub: 1.2,
        pin: true,
        pinSpacing: true,
        invalidateOnRefresh: true
      }
    });

    // 2. Scroll-driven Narrative Timeline
    heroTl
      // Image Zoom & Parallax
      .to(heroImage, { 
        scale: 1.3, 
        yPercent: 12,
        ease: 'none'
      }, 0)
      
      // State 1 -> State 2 (at 30%)
      .to(state1, { opacity: 0, y: -40, duration: 0.2 }, 0.3)
      .fromTo(state2, 
        { opacity: 0, y: 40 }, 
        { opacity: 1, y: 0, duration: 0.2 }, 
        0.35
      )

      // State 2 -> State 3 (at 55%)
      .to(state2, { opacity: 0, y: -40, duration: 0.15 }, 0.5)
      .fromTo(state3, 
        { opacity: 0, y: 40 }, 
        { opacity: 1, y: 0, duration: 0.15 }, 
        0.55
      )

      // Meta Appearance (with State 3)
      .to(heroMeta, { opacity: 1, y: 0, duration: 0.2 }, 0.6)
      
  }


  // ── High-Precision Split Portfolio ───────────────────────
  const storyContainer = document.getElementById('projects-story-container');
  const storyInner = storyContainer?.querySelector('.projects-story-inner');
  const images = document.querySelectorAll('.project-story-img');
  const texts = document.querySelectorAll('.project-story-text');
  
  if (storyContainer && storyInner && window.innerWidth >= 1024) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: storyContainer,
        start: "top top",
        end: () => "+=" + (images.length * 100 + 100) + "%",
        scrub: true,
        pin: true,
        anticipatePin: 1,
        pinSpacing: false
      }
    });

    images.forEach((img, i) => {
      const nextImage = images[i + 1];
      const text = texts[i];

      // 1. ENTRY
      tl.to(img, {
        opacity: 1,
        scale: 1,
        duration: 0.8,
        ease: "power2.out"
      }, i > 0 ? ">-0.4" : undefined);

      tl.fromTo(text, {
        opacity: 0,
        y: 40
      }, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power2.out"
      }, "<");

      // 2. HOLD (Stability) - last project stays much longer
      tl.to({}, { duration: nextImage ? 0.6 : 4.0 });

      // 3. EXIT TEXT
      if (nextImage) {
        tl.to(text, {
          opacity: 0,
          y: -20,
          duration: 0.5,
          ease: "power2.in"
        });
      }

      // 4. TRANSITION TO NEXT
      if (nextImage) {
        tl.to(img, {
          opacity: 0,
          scale: 1.05,
          duration: 0.8,
          ease: "power2.inOut"
        });

        tl.fromTo(nextImage, {
          opacity: 0,
          scale: 1.1
        }, {
          opacity: 1,
          scale: 1,
          duration: 0.8,
          ease: "power2.out"
        }, "<");
      }
    });
  }

  // ── Scroll indicator fade ─────────────────────────────────────
  const scrollIndicator = document.getElementById('hero-scroll-indicator');
  if (scrollIndicator) {
    ScrollTrigger.create({
      trigger: document.body,
      start: '80px top',
      onEnter:  () => gsap.to(scrollIndicator, { opacity: 0, duration: 0.5 }),
      onLeaveBack: () => gsap.to(scrollIndicator, { opacity: 1, duration: 0.5 })
    });
  }
</script>

