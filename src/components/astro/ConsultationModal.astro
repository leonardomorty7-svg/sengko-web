---
// ConsultationModal.astro
---

<div id="consultation-modal" class="fixed inset-0 z-[100] flex items-center justify-center pointer-events-none opacity-0 transition-opacity duration-500">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="consultation-backdrop"></div>
  
  <!-- Modal Container -->
  <div class="relative w-full max-w-2xl bg-[#0A0A0A] border border-white/10 p-8 md:p-12 shadow-[0_0_50px_rgba(0,0,0,0.8)] transform scale-95 transition-transform duration-500 opacity-0" id="consultation-content">
    
    <!-- Close Button -->
    <button id="consultation-close" class="absolute top-6 right-6 text-white/50 hover:text-white transition-colors p-2" aria-label="Cerrar modal">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Header -->
    <div class="mb-10">
      <span class="text-[var(--color-primary)] text-[10px] tracking-[0.25em] font-medium uppercase mb-4 block">
        Ingeniería Especializada
      </span>
      <h3 class="text-3xl md:text-4xl font-medium tracking-tight text-white leading-[1.1]">
        Consulta Técnica
      </h3>
      <p class="text-white/50 text-sm mt-4 font-light max-w-[45ch]">
        Describa brevemente los requerimientos de su proyecto. Nuestro equipo de ingeniería estructural analizará su caso.
      </p>
    </div>

    <!-- Form -->
    <form id="consultation-form" class="space-y-6" onsubmit="event.preventDefault();">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Nombre -->
        <div class="form-group">
          <label for="name" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Nombre completo</label>
          <input type="text" id="name" required class="w-full bg-white/5 border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light" placeholder="Ej. Carlos Mendoza">
        </div>
        <!-- Empresa -->
        <div class="form-group">
          <label for="company" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Empresa</label>
          <input type="text" id="company" required class="w-full bg-white/5 border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light" placeholder="Nombre de su organización">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Email -->
        <div class="form-group">
          <label for="email" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Correo electrónico</label>
          <input type="email" id="email" required class="w-full bg-white/5 border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light" placeholder="correo@empresa.com">
        </div>
        <!-- Teléfono -->
        <div class="form-group">
          <label for="phone" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Teléfono</label>
          <input type="tel" id="phone" required class="w-full bg-white/5 border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light" placeholder="+57 300 000 0000">
        </div>
      </div>

      <!-- Tipo de proyecto -->
      <div class="form-group">
        <label for="project-type" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Tipo de proyecto</label>
        <select id="project-type" required class="w-full bg-[#111] border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light appearance-none cursor-pointer">
          <option value="" disabled selected>Seleccione una categoría</option>
          <option value="bodega">Estructura Metálica Bodegas</option>
          <option value="cubierta">Cubierta Metálica</option>
          <option value="infraestructura">Infraestructura</option>
          <option value="edificacion">Edificación</option>
          <option value="otro">Otro</option>
        </select>
      </div>

      <!-- Mensaje -->
      <div class="form-group">
        <label for="message" class="block text-white/40 text-[9px] uppercase tracking-[0.15em] mb-2">Mensaje / Requerimientos</label>
        <textarea id="message" required rows="4" class="w-full bg-white/5 border border-white/10 px-4 py-3 text-white text-sm focus:border-[var(--color-primary)] focus:bg-white/10 transition-colors outline-none font-light resize-none" placeholder="Describa área, tonelaje estimado o detalles técnicos..."></textarea>
      </div>

      <!-- Submit -->
      <div class="pt-4">
        <button type="submit" id="consultation-submit" class="w-full bg-[var(--color-primary)] text-black py-4 text-[10px] font-semibold tracking-[0.16em] uppercase hover:bg-white transition-all duration-400">
          Enviar Requerimiento
        </button>
      </div>
    </form>

    <!-- Success State (Hidden by default) -->
    <div id="consultation-success" class="hidden absolute inset-0 bg-[#0A0A0A] flex-col items-center justify-center p-12 text-center">
      <div class="w-16 h-16 rounded-full border border-[var(--color-primary)] flex items-center justify-center mb-6">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2">
          <path d="M20 6L9 17l-5-5"></path>
        </svg>
      </div>
      <h4 class="text-2xl text-white font-medium mb-3">Requerimiento Recibido</h4>
      <p class="text-white/50 text-sm font-light max-w-[30ch] mb-8">
        Nuestro equipo de ingeniería revisará su solicitud y le contactará a la brevedad.
      </p>
      <button id="consultation-success-close" class="px-8 py-3 border border-white/20 text-white text-[9px] font-medium tracking-[0.16em] uppercase hover:bg-white hover:text-black transition-colors">
        Cerrar
      </button>
    </div>
  </div>
</div>

<script>
  // Simple modal logic
  const modal = document.getElementById('consultation-modal');
  const content = document.getElementById('consultation-content');
  const backdrop = document.getElementById('consultation-backdrop');
  const closeBtn = document.getElementById('consultation-close');
  const form = document.getElementById('consultation-form') as HTMLFormElement;
  const submitBtn = document.getElementById('consultation-submit');
  const successState = document.getElementById('consultation-success');
  const successCloseBtn = document.getElementById('consultation-success-close');

  const openTriggers = document.querySelectorAll('[data-modal-trigger="consultation"]');

  function openModal() {
    if (!modal || !content) return;
    modal.classList.remove('pointer-events-none');
    modal.classList.add('opacity-100');
    modal.classList.remove('opacity-0');
    
    setTimeout(() => {
      content.classList.remove('scale-95', 'opacity-0');
      content.classList.add('scale-100', 'opacity-100');
    }, 50);

    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal || !content) return;
    content.classList.remove('scale-100', 'opacity-100');
    content.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0');
      modal.classList.add('pointer-events-none');
      document.body.style.overflow = '';
      
      // Reset form state
      setTimeout(() => {
        if(form) form.reset();
        if(successState) successState.classList.add('hidden');
        if(successState) successState.classList.remove('flex');
        if(form) form.style.opacity = '1';
        if(form) form.style.pointerEvents = 'auto';
      }, 500);
    }, 300);
  }

  // Event Listeners
  openTriggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      openModal();
    });
  });

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  successCloseBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('opacity-100')) {
      closeModal();
    }
  });

  // Handle Submit
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if(submitBtn) {
      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Enviando...';
      submitBtn.setAttribute('disabled', 'true');
      
      // Simulate network request
      setTimeout(() => {
        form.style.opacity = '0';
        form.style.pointerEvents = 'none';
        
        setTimeout(() => {
          successState?.classList.remove('hidden');
          successState?.classList.add('flex');
          submitBtn.innerHTML = originalText;
          submitBtn.removeAttribute('disabled');
        }, 300);
      }, 1000);
    }
  });
</script>
