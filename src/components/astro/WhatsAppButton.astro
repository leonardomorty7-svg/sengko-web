---
// src/components/astro/WhatsAppButton.astro

/**
 * CONFIGURACIÓN EDITABLE
 * Permite cambiar el número y el mensaje predeterminado fácilmente.
 */
const whatsappConfig = {
  phone: "573001112233", // Formato: Código de país + número (sin el signo +)
  message: "Hola, me gustaría recibir más información sobre sus servicios de ingeniería."
};

const encodedMessage = encodeURIComponent(whatsappConfig.message);
const whatsappUrl = `https://wa.me/${whatsappConfig.phone}?text=${encodedMessage}`;
---

<a 
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-float flex items-center justify-center transition-all duration-500 hover:scale-110 active:scale-95"
  aria-label="Contactar por WhatsApp"
>
  <svg 
    width="22" 
    height="22" 
    viewBox="0 0 24 24" 
    fill="currentColor" 
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
  </svg>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 7rem; /* Sits above the Chatbot bubble (which is at 2rem) */
    right: 2rem;
    width: 3.5rem;
    height: 3.5rem;
    background-color: var(--color-bg-soft);
    color: var(--color-primary);
    border: 1px solid rgba(183, 245, 0, 0.3);
    z-index: 80;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    /* Enforcing the industrial aesthetic: sharp corners */
    border-radius: 0px;
  }

  .whatsapp-float::after {
    content: '';
    position: absolute;
    inset: -1px;
    background: var(--color-primary);
    opacity: 0;
    z-index: -1;
    transition: opacity 0.4s ease;
  }

  .whatsapp-float:hover {
    background-color: var(--color-primary);
    color: black;
    border-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .whatsapp-float {
      bottom: 5.5rem;
      right: 1rem;
      width: 3.2rem;
      height: 3.2rem;
    }
  }
</style>
