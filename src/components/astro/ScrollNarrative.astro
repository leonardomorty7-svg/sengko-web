---
// CINEMATIC SCROLL NARRATIVE
// GSAP ScrollTrigger · 400vh · scrub 1.2 · staggered in/out
---

<section id="process-section" class="process-section">

  <div class="process-sticky" id="process-sticky">

    <!-- ── RIGHT: images (behind) ── -->
    <div class="process-right" id="process-right">
      {[
        '/images/services/process/process-01-structure.jpg',
        '/images/services/process/process-02-precision.jpg',
        '/images/services/process/process-03-execution.jpg',
        '/images/services/process/process-04-result.jpg',
      ].map((src, i) => (
        <div class="process-img-wrap" data-img={i}>
          <img
            src={src}
            alt={`Proceso ${i + 1}`}
            class="process-img"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}

    </div>

    <!-- ── LEFT: text panel (in front) ── -->
    <div class="process-left">
      <span class="process-eyebrow">Proceso</span>

      <div class="process-text-stage">
        {[
          {
            num: '01',
            title: 'Estructura',
            body: 'Calculamos y optimizamos cada elemento estructural bajo normativa estricta. El diseño es el fundamento de todo lo que construimos.'
          },
          {
            num: '02',
            title: 'Precisión',
            body: 'Modelamos digitalmente cada pieza antes de fabricarla. El BIM garantiza que lo diseñado sea exactamente lo que se construye.'
          },
          {
            num: '03',
            title: 'Ejecución',
            body: 'Fabricamos, transportamos y montamos con equipos especializados. Cada obra es una demostración de excelencia técnica.'
          },
          {
            num: '04',
            title: 'Resultado',
            body: 'Infraestructura de alto desempeño que perdura. Proyectos que reflejan la precisión de quienes los construyeron.'
          }
        ].map((s, i) => (
          <div class="process-slide" data-slide={i}>
            <span class="process-num">{s.num}</span>
            <h2 class="process-title">{s.title}</h2>
            <p class="process-body">{s.body}</p>
          </div>
        ))}
      </div>

      <!-- Progress line -->
      <div class="process-progress-track">
        <div class="process-progress-fill" id="proc-progress"></div>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── Section: 400vh scroll space ── */
  .process-section {
    height: 400vh;
    background: var(--color-bg);
  }

  /* ── Sticky container ── */
  .process-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  /* ── RIGHT: image layer ── */
  .process-right {
    position: relative;
    overflow: hidden;
  }

  .process-img-wrap {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity, transform;
  }
  .process-img-wrap[data-img="0"] { opacity: 1; }

  .process-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    will-change: transform;
    transform: scale(1.06) translateX(20px);
  }
  .process-img-wrap[data-img="0"] .process-img {
    transform: scale(1) translateX(0);
  }


  /* ── LEFT: text panel ── */
  .process-left {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: clamp(18vh, 22vh, 28vh) clamp(2rem, 5vw, 5.5rem) 0;
    background: transparent;
  }

  .process-eyebrow {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 3.5rem;
  }

  /* ── Text stage: stacked, GSAP drives opacity/transform ── */
  .process-text-stage {
    position: relative;
    min-height: 320px;
  }

  .process-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    will-change: opacity, transform;
    pointer-events: none;
  }
  .process-slide[data-slide="0"] { opacity: 1; }

  .process-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
  }

  .process-title {
    font-family: var(--font-heading);
    font-size: clamp(52px, 6.5vw, 96px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: #ffffff;
    margin-bottom: 2rem;
  }

  .process-body {
    font-size: 1.125rem;
    font-weight: 300;
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: rgba(255,255,255,0.75);
    max-width: 440px;
  }

  /* ── Progress bar ── */
  .process-progress-track {
    width: 100%;
    max-width: 360px;
    height: 1px;
    background: rgba(255,255,255,0.1);
    margin-top: 4rem;
    overflow: hidden;
  }

  .process-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary);
    transform-origin: left;
    will-change: width;
  }

  /* ── Mobile: unstack ── */
  @media (max-width: 1023px) {
    .process-section { height: auto; }
    .process-sticky {
      position: relative;
      height: auto;
      grid-template-columns: 1fr;
    }
    .process-right { height: 55vw; min-height: 300px; }
    .process-img-wrap { position: absolute; opacity: 0; }
    .process-img-wrap[data-img="0"] { opacity: 1; }
    .process-img { transform: none !important; }
    .process-text-stage { position: relative; min-height: auto; }
    .process-slide {
      position: relative;
      opacity: 1 !important;
      transform: none !important;
      pointer-events: auto;
      margin-bottom: 3rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding-bottom: 3rem;
    }
    .process-slide:last-child { border: none; }
    .process-left-vignette { display: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isMobile = window.innerWidth < 1024;
  if (isMobile) {
    // Mobile: nothing to do — CSS handles it
  } else {

    const section  = document.getElementById('process-section')!;
    const sticky   = document.getElementById('process-sticky')!;
    const slides   = gsap.utils.toArray<HTMLElement>('.process-slide');
    const imgWraps = gsap.utils.toArray<HTMLElement>('.process-img-wrap');
    const imgs     = imgWraps.map(w => w.querySelector<HTMLElement>('.process-img')!);
    const progress = document.getElementById('proc-progress')!;
    const STEPS    = slides.length; // 4
    const STEP     = 1 / STEPS;    // 0.25

    // ── Master timeline (paused, driven by ScrollTrigger) ──
    const master = gsap.timeline({ paused: true });

    slides.forEach((slide, i) => {
      const imgWrap = imgWraps[i];
      const img     = imgs[i];

      const num   = slide.querySelector('.process-num')!;
      const title = slide.querySelector('.process-title')!;
      const body  = slide.querySelector('.process-body')!;

      // Define distinct timeline windows for each slide
      // Slides overlap slightly to create the cinematic crossfade
      const enterTime = i - 0.2; 
      const exitTime  = i + 0.8;

      // ─── IMAGE CONTINUITY ───
      if (i === 0) {
        master.set(imgWrap, { opacity: 1 }, 0);
        master.set(img, { scale: 1, x: 0 }, 0);
      } else {
        master.fromTo(imgWrap,
          { opacity: 0 },
          { opacity: 1, duration: 0.5, ease: 'power2.inOut' },
          enterTime
        );
        master.fromTo(img,
          { scale: 1.08, x: 20 },
          { scale: 1, x: 0, duration: 0.7, ease: 'power3.out' },
          enterTime
        );
      }

      if (i < STEPS - 1) {
        master.to(imgWrap, {
          opacity: 0, duration: 0.5, ease: 'power2.inOut'
        }, exitTime);
        master.to(img, {
          scale: 1.04, x: -10, duration: 0.6, ease: 'power2.in'
        }, exitTime);
      }

      // Continuous subtle parallax over active duration
      master.to(img, {
        yPercent: -5, ease: 'none', duration: 1.2
      }, Math.max(0, enterTime));


      // ─── TEXT ARCHITECTURAL REVEAL ───
      if (i === 0) {
        master.set(slide, { opacity: 1 }, 0);
        master.set([num, title, body], { opacity: 1, y: 0 }, 0);
      } else {
        master.set(slide, { opacity: 0 }, 0);
        master.set([num, title, body], { opacity: 0, y: 30 }, 0);
        
        master.to(slide, { opacity: 1, duration: 0.1 }, enterTime);
        master.to(num, { opacity: 1, y: 0, duration: 0.4, ease: 'power3.out' }, enterTime + 0.1);
        master.to(title, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, enterTime + 0.15);
        master.to(body, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, enterTime + 0.2);
      }

      if (i < STEPS - 1) {
        master.to(num, { opacity: 0, y: -20, duration: 0.3, ease: 'power2.inOut' }, exitTime);
        master.to(title, { opacity: 0, y: -25, duration: 0.35, ease: 'power2.inOut' }, exitTime + 0.05);
        master.to(body, { opacity: 0, y: -15, duration: 0.3, ease: 'power2.inOut' }, exitTime + 0.1);
        master.to(slide, { opacity: 0, duration: 0.1 }, exitTime + 0.45);
      }
    });

    // ─── ScrollTrigger ─────────────────────────────────────
    ScrollTrigger.create({
      trigger: section,
      start:  'top top',
      end:    'bottom bottom',
      scrub:  1.2,
      pin:    sticky,
      pinSpacing: false,
      onUpdate: (self) => {
        master.progress(self.progress);
        progress.style.width = `${self.progress * 100}%`;
      }
    });
  }
</script>
