---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  centered?: boolean;
}

const { title, subtitle, label, centered = false } = Astro.props;
---

<div class={`mb-16 md:mb-24 ${centered ? 'text-center' : ''}`}>
  {label && (
    <small class="inline-block text-[var(--color-primary)] font-medium tracking-[0.08em] text-xs uppercase mb-6">
      {label}
    </small>
  )}
  <h2 class="text-4xl md:text-[clamp(40px,5vw,72px)] font-medium tracking-tight leading-tight mb-8 max-w-[14ch]" set:html={title} />
  {subtitle && (
    <p class={`text-lg font-normal leading-relaxed text-white/70 max-w-2xl ${centered ? 'mx-auto' : ''}`}>
      {subtitle}
    </p>
  )}
</div>
