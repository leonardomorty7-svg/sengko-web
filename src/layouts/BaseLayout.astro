---
import '../styles/global.css';
import { siteConfig } from '../data/site-config';

import Header from '../components/astro/Header.astro';
import WhatsAppButton from '../components/astro/WhatsAppButton.astro';
import SupportButton from '../components/astro/SupportButton.astro';
import ConsultationModal from '../components/astro/ConsultationModal.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: URL | string;
}

const { 
  title = siteConfig.title, 
  description = siteConfig.description, 
  image = siteConfig.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site || siteConfig.url)
} = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteConfig.url}/#organization`,
      "name": "SENGKO",
      "url": siteConfig.url,
      "logo": `${siteConfig.url}/images/branding/logo-sengko-primary.svg`,
      "description": siteConfig.description,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": siteConfig.contact.email,
        "telephone": siteConfig.contact.phone,
        "contactType": "customer service"
      },
      "sameAs": [
        siteConfig.social.linkedin,
        siteConfig.social.twitter
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteConfig.url}/#localbusiness`,
      "name": "SENGKO Ingeniería",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": siteConfig.contact.address
      },
      "telephone": siteConfig.contact.phone,
      "url": siteConfig.url
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/images/branding/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={siteConfig.keywords.join(', ')} />
    <meta name="author" content={siteConfig.author} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </head>
  <body>
    <Header />
    <slot />
    <SupportButton />
    <WhatsAppButton />
    <ConsultationModal />
  </body>
</html>

<style is:global>
  :root {
    --font-heading: 'Outfit', sans-serif;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
</style>
